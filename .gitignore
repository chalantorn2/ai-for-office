# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Secrets — DB credentials, JWT signing key, Anthropic API key.
# The main repo hardcoded these in api/config.php; do not repeat that here.
api/config.local.php
deploy.secret.ps1
.env
.env.*
!.env.example

# Images staff attached to a question. Private customer-facing material, and it
# belongs to the deployment rather than the source — the .htaccess that closes
# the directory to the web is tracked, nothing under it is.
api/uploads/*
!api/uploads/.htaccess

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
